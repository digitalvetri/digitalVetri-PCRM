// DigitalVetri AI Sales Intelligence Platform - Data Model
// PostgreSQL via Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Users & Access Control
// ============================================================

enum Role {
  ADMIN
  MANAGER
  SALES
  VIEWER
  EMPLOYEE
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  name      String
  imageUrl  String?
  role      Role     @default(SALES)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedProspects Prospect[] @relation("AssignedProspects")
  tasks             Task[]     @relation("AssignedTasks")
  createdTasks      Task[]     @relation("CreatedTasks")
  activities        Activity[]
  followUps         FollowUp[]
  meetings          Meeting[]
  proposals         Proposal[]
  notes             Note[]

  // HRMS (role = EMPLOYEE)
  employeeProfile     EmployeeProfile?
  projectAssignments  ProjectAssignment[]
  attendance          Attendance[]
  leaveRequests       LeaveRequest[]      @relation("EmployeeLeaves")
  reviewedLeaves      LeaveRequest[]      @relation("LeaveReviewer")
  salaryRecords       SalaryRecord[]
  performanceReviews  PerformanceReview[] @relation("EmployeeReviews")
  authoredReviews     PerformanceReview[] @relation("ReviewAuthor")
  chatMessages        ChatMessage[]
  announcements       Announcement[]
  timesheets          TimesheetEntry[]
  kbArticles          KbArticle[]
  goals               Goal[]              @relation("GoalOwner")

  @@index([clerkId])
  @@index([role])
}

/// Company-wide team chat (single channel). Near-real-time via polling.
model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  body      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

/// Company announcements posted by admins, visible to everyone.
model Announcement {
  id        String   @id @default(cuid())
  authorId  String
  title     String
  body      String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}

/// Employee-logged hours per day (optionally against a project).
model TimesheetEntry {
  id        String   @id @default(cuid())
  userId    String
  projectId String?
  date      DateTime
  hours     Float
  note      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

/// Internal knowledge base / wiki. Admins author, everyone reads.
model KbArticle {
  id        String   @id @default(cuid())
  title     String
  body      String
  category  String?
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([category])
}

/// Company holidays (shown on attendance calendars).
model Holiday {
  id   String   @id @default(cuid())
  date DateTime @unique
  name String
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

/// Employee goals / OKRs with measurable progress.
model Goal {
  id          String     @id @default(cuid())
  userId      String
  title       String
  detail      String?
  target      Float      @default(100)
  current     Float      @default(0)
  unit        String?
  dueDate     DateTime?
  status      GoalStatus @default(ACTIVE)
  createdById String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user User @relation("GoalOwner", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================
// Company Intelligence
// ============================================================

enum ImportSource {
  MANUAL
  EXCEL
  CSV
  GOOGLE_MAPS
  LINKEDIN
  WEBSITE
}

enum DataConfidence {
  VERIFIED // confirmed from an authoritative public source
  ESTIMATED // AI/heuristic estimate - must be displayed as such
  UNKNOWN
}

model Company {
  id     String @id @default(cuid())
  name   String
  slug   String @unique
  domain String?

  website     String?
  industry    String?
  subIndustry String?
  city        String?
  state       String?
  country     String? @default("India")
  address     String?
  latitude    Float?
  longitude   Float?

  // Estimates - always flagged with confidence so UI can distinguish
  // verified facts from AI estimates
  employeeEstimate    Int?
  employeeConfidence  DataConfidence @default(UNKNOWN)
  revenueEstimate     String? // e.g. "₹5-10 Cr"
  revenueConfidence   DataConfidence @default(UNKNOWN)

  products          String[]
  services          String[]
  // DigitalVetri services we are pursuing this client for (from the SERVICES list).
  targetServices    String[]
  technologyStack   String[]
  socialMedia       Json? // { linkedin, facebook, instagram, twitter, youtube }
  manufacturingType String?
  departments       String[]

  googleRating     Float?
  googleReviews    Int?
  linkedinUrl      String?
  linkedinPresence Boolean @default(false)

  phone       String?
  publicEmail String?
  gstNumber   String? // only if publicly available

  importSource ImportSource @default(MANUAL)
  sourceUrl    String? // original Maps/LinkedIn/website URL used for import
  rawImportData Json? // untouched import payload for audit

  // Client lifecycle (Phase 1) — the relationship stage, distinct from the
  // sales pipeline. Set when a prospect is won.
  relationship ClientStatus @default(PROSPECT)
  clientSince  DateTime? // first deal won

  analyzedAt DateTime? // last AI analysis run
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  analysis         CompanyAnalysis?
  prospects        Prospect[]
  decisionMakers   DecisionMaker[]
  leadIntelligence LeadIntelligence?
  recommendation   CrmRecommendation?
  meetings         Meeting[]
  proposals        Proposal[]
  revenueEntries   RevenueEntry[]
  generatedContent GeneratedContent[]
  activities       Activity[]
  notes            Note[]
  projects         Project[]

  @@index([industry])
  @@index([city])
  @@index([state])
  @@index([name])
  @@index([createdAt])
}

// Decision makers - stored ONLY when publicly available (company website,
// public LinkedIn page, published directories)
model DecisionMaker {
  id          String  @id @default(cuid())
  companyId   String
  name        String
  designation String?
  linkedinUrl String?
  email       String? // public email only
  phone       String? // public phone only
  isPrimary   Boolean @default(false)
  source      String? // where this was publicly found
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

// ============================================================
// AI Company Analysis (scores are ESTIMATES by definition)
// ============================================================

enum LeadGrade {
  A_PLUS
  A
  B
  C
}

enum Priority {
  URGENT
  HIGH
  MEDIUM
  LOW
}

model CompanyAnalysis {
  id        String @id @default(cuid())
  companyId String @unique

  businessSummary String

  digitalMaturityScore Int // 0-100
  automationScore      Int // 0-100
  crmOpportunityScore  Int // 0-100
  erpOpportunityScore  Int // 0-100
  aiOpportunityScore   Int // 0-100
  leadScore            Int // 0-100 composite
  leadGrade            LeadGrade
  priority             Priority

  painPoints       Json // [{ area, prediction, reasoning }]
  suggestedModules String[]
  expectedBudget   String? // e.g. "₹8-15 Lakh"
  buyingProbability Int // 0-100

  scoreBreakdown Json? // per-factor contributions for transparency
  aiProvider     String? // which model generated this
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([leadGrade])
  @@index([leadScore])
  @@index([automationScore])
  @@index([crmOpportunityScore])
}

// ============================================================
// Lead Intelligence Engine (industry-based predictions)
// ============================================================

model LeadIntelligence {
  id        String @id @default(cuid())
  companyId String @unique

  // Each entry: { likelihood: 0-100, details: string, reasoning: string }
  businessChallenges       Json
  manualProcesses          Json
  excelUsage               Json
  approvalBottlenecks      Json
  inventoryProblems        Json
  salesProblems            Json
  productionDelays         Json
  communicationProblems    Json
  reportingProblems        Json
  customerManagementIssues Json

  overallInsight String?
  aiProvider     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ============================================================
// CRM Recommendation Engine
// ============================================================

model CrmRecommendation {
  id        String @id @default(cuid())
  companyId String @unique

  recommendedModules Json // [{ module, reason, priority }]
  estimatedHours     Int
  estimatedTimeline  String // e.g. "14-18 weeks"
  estimatedTeamSize  Int
  estimatedCost      Float // INR
  costRange          String? // "₹8,00,000 - ₹12,00,000"
  expectedRoi        String // e.g. "3.2x in 18 months"
  annualSavings      Float // INR
  savingsBreakdown   Json? // [{ area, amount, explanation }]

  aiProvider String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

// ============================================================
// Prospect Pipeline
// ============================================================

enum ProspectStatus {
  NEW
  RESEARCHING
  QUALIFIED
  CONTACTED
  MEETING_SCHEDULED
  MEETING_DONE
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
  ON_HOLD
  DISQUALIFIED
}

/// Engagement type — a one-off project vs. recurring income (AMC / retainer).
enum DealType {
  ONE_TIME
  AMC
  RETAINER
}

/// Billing frequency for recurring deals; used to normalise to monthly (MRR).
enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

/// The client relationship stage, distinct from the sales pipeline status.
enum ClientStatus {
  PROSPECT
  ACTIVE
  AMC
  DORMANT
  CHURNED
}

/// What a revenue entry is for.
enum RevenueKind {
  PROJECT
  AMC
  ADDON
}

/// Billing/collection state of a revenue entry.
enum PaymentStatus {
  DRAFT
  INVOICED
  PAID
  OVERDUE
}

/// A dated money event for a client — the ledger behind month-by-month revenue,
/// profit (amount − cost) and receivables. One row per invoice/milestone/AMC bill.
model RevenueEntry {
  id         String @id @default(cuid())
  companyId  String
  prospectId String? // which deal it came from (Phase 3 will add a Deal link)

  date   DateTime // recognition date — the month this revenue belongs to
  kind   RevenueKind   @default(PROJECT)
  amount Float // billed (revenue), INR
  cost   Float         @default(0) // delivery cost → profit = amount − cost
  status PaymentStatus @default(INVOICED)

  invoiceNo String?
  dueDate   DateTime?
  paidAt    DateTime?
  gstAmount Float?
  note      String?

  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  prospect Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([date])
  @@index([status])
}

model Prospect {
  id         String @id @default(cuid())
  prospectId String @unique // human-friendly: DV-P-0001
  // A prospect IS a deal/engagement. A company can hold many over its lifetime
  // (website → AMC → app), so companyId is intentionally NOT unique.
  companyId  String

  status       ProspectStatus @default(NEW)
  assignedToId String?

  lastContactDate   DateTime?
  nextFollowUpDate  DateTime?
  proposalValue     Float? // INR
  expectedCloseDate DateTime?
  probability       Int? // 0-100
  lostReason        String?

  // Timestamp of the transition into WON — the true "closed" date for revenue
  // reporting. Distinct from updatedAt (which any later edit bumps).
  wonAt DateTime?

  // Engagement / recurring-revenue (Phase 1). One-time uses proposalValue;
  // AMC/RETAINER use recurringAmount + billingCycle (normalised to monthly MRR).
  dealType        DealType      @default(ONE_TIME)
  recurringAmount Float? // INR per billing cycle
  billingCycle    BillingCycle?
  contractStart   DateTime?
  contractEnd     DateTime?
  renewalDate     DateTime? // when this AMC/retainer next comes up for renewal

  syncedToCrm   Boolean   @default(false)
  crmSyncedAt   DateTime?
  crmExternalId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assignedTo     User?          @relation("AssignedProspects", fields: [assignedToId], references: [id])
  followUps      FollowUp[]
  tasks          Task[]
  revenueEntries RevenueEntry[]

  @@index([companyId])
  @@index([status])
  @@index([assignedToId])
  @@index([nextFollowUpDate])
  @@index([wonAt])
}

/// A ready-to-send outreach message drafted for a lead (queued for review).
model OutreachDraft {
  id               String   @id @default(cuid())
  discoveredLeadId String?
  leadName         String
  channel          String // EMAIL | WHATSAPP
  toContact        String? // email or phone
  subject          String?
  body             String
  status           String   @default("DRAFT") // DRAFT | SENT | DISMISSED
  createdById      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

/// A connected Meta ad account — the agency's own or a client's — for in-app
/// campaign reporting and AI analysis. The access token (an ads_read
/// system-user token) is server-only and never returned to the browser.
model AdConnection {
  id          String   @id @default(cuid())
  name        String // e.g. "DigitalVetri (own)" or the client's business name
  adAccountId String // "act_..." (normalized on save)
  accessToken String
  currency    String? // detected from the account on connect
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Log of an autonomous agent run (daily discovery + morning briefing), so the
/// overnight work is observable in-app even before send-channels are wired.
model AgentRun {
  id         String   @id @default(cuid())
  type       String   @default("daily") // daily | discover | digest
  status     String   @default("SUCCESS") // SUCCESS | PARTIAL | FAILED
  summary    String? // the briefing text
  leadsFound Int      @default(0)
  sent       Boolean  @default(false)
  data       Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([type])
}

enum DiscoveredLeadStatus {
  NEW
  QUALIFIED
  PROMOTED
  DISMISSED
}

/// A business discovered/qualified by the prospecting engine, kept separate
/// from Company until it's promoted (graduates) into the pipeline.
model DiscoveredLead {
  id                 String               @id @default(cuid())
  name               String
  website            String?
  phone              String?
  email              String?
  city               String?
  state              String?
  industry           String?
  source             String               @default("MANUAL") // MANUAL | PLACES | SEED
  signals            Json? // string[] of detected need signals
  recommendedService String?
  summary            String?
  needScore          Int                  @default(0)
  fitScore           Int                  @default(0)
  totalScore         Int                  @default(0)
  status             DiscoveredLeadStatus @default(NEW)
  promotedCompanyId  String?
  createdById        String?

  // Ad attribution (from /enquiry UTM params) — which paid campaign brought
  // this lead, so spend can be joined to actual CRM leads for true CPL.
  utmSource   String?
  utmCampaign String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([totalScore])
  @@index([createdAt])
}

model Note {
  id        String   @id @default(cuid())
  companyId String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])

  @@index([companyId])
  @@index([authorId])
}

// ============================================================
// Discovery Meetings
// ============================================================

enum MeetingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
  NO_SHOW
}

enum MeetingType {
  DISCOVERY
  DEMO
  PROPOSAL_REVIEW
  NEGOTIATION
  KICKOFF
  FOLLOW_UP
}

model Meeting {
  id        String @id @default(cuid())
  companyId String
  userId    String

  title       String
  type        MeetingType   @default(DISCOVERY)
  status      MeetingStatus @default(SCHEDULED)
  scheduledAt DateTime
  duration    Int           @default(60) // minutes
  location    String? // or meeting link
  agenda      String?
  outcome     String?

  // Discovery questionnaire: [{ section, questions: [{ q, answer, notes }] }]
  questionnaire Json?
  questionnaireIndustry String?
  pdfUrl        String? // exported questionnaire PDF in Supabase Storage

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([scheduledAt])
  @@index([status])
  @@index([userId])
}

// ============================================================
// Proposals
// ============================================================

enum ProposalStatus {
  DRAFT
  SENT
  VIEWED
  UNDER_DISCUSSION
  ACCEPTED
  REJECTED
  EXPIRED
}

model Proposal {
  id         String @id @default(cuid())
  proposalNo String @unique // DV-PR-0001
  companyId  String
  userId     String

  title  String
  status ProposalStatus @default(DRAFT)

  // Full structured document: { coverPage, companyOverview, currentProblems,
  //   recommendedSolution, scope, modules, timeline, deliverables,
  //   technology, pricing, milestones, amc, support, terms, signature }
  content Json

  totalValue Float // INR
  amcValue   Float? // annual
  validUntil DateTime?
  sentAt     DateTime?
  pdfUrl     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([userId])
  @@index([validUntil])
}

// ============================================================
// Generated Content (emails + WhatsApp messages)
// ============================================================

enum ContentChannel {
  EMAIL
  WHATSAPP
}

enum ContentCategory {
  COLD_OUTREACH
  FOLLOW_UP
  MEETING_REQUEST
  MEETING_REMINDER
  PROPOSAL_FOLLOW_UP
  PROPOSAL_REMINDER
  THANK_YOU
  FIRST_CONTACT
  FESTIVAL_GREETING
  REVIEW_REQUEST
  REFERRAL_REQUEST
}

model GeneratedContent {
  id        String @id @default(cuid())
  companyId String?

  channel  ContentChannel
  category ContentCategory
  subject  String? // email only
  body     String
  tone     String?
  language String @default("en")

  aiProvider String?
  isSent     Boolean   @default(false)
  sentAt     DateTime?
  createdAt  DateTime  @default(now())

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([channel, category])
}

// ============================================================
// Follow-ups & Tasks
// ============================================================

enum FollowUpStatus {
  PENDING
  DONE
  SKIPPED
  RESCHEDULED
}

enum FollowUpChannel {
  CALL
  EMAIL
  WHATSAPP
  MEETING
  LINKEDIN
  OTHER
}

model FollowUp {
  id         String @id @default(cuid())
  prospectId String
  userId     String

  dueAt   DateTime
  channel FollowUpChannel @default(CALL)
  status  FollowUpStatus  @default(PENDING)
  notes   String?
  outcome String?
  completedAt DateTime?

  // True for the follow-up auto-created to mirror Prospect.nextFollowUpDate.
  // Lets the pipeline↔follow-up bridge find and update its own row instead of
  // matching on an exact dueAt (which drifts / duplicates).
  autoSynced Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@index([dueAt])
  @@index([status])
  @@index([userId])
  @@index([prospectId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

model Task {
  id String @id @default(cuid())

  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  completedAt DateTime?

  assignedToId String?
  createdById  String
  prospectId   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedTo User?     @relation("AssignedTasks", fields: [assignedToId], references: [id])
  createdBy  User      @relation("CreatedTasks", fields: [createdById], references: [id])
  prospect   Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([assignedToId])
  @@index([dueDate])
  @@index([createdById])
  @@index([prospectId])
}

// ============================================================
// Activity Feed
// ============================================================

enum ActivityType {
  COMPANY_IMPORTED
  COMPANY_ANALYZED
  PROSPECT_CREATED
  STATUS_CHANGED
  MEETING_SCHEDULED
  MEETING_COMPLETED
  PROPOSAL_CREATED
  PROPOSAL_SENT
  EMAIL_GENERATED
  EMAIL_SENT
  WHATSAPP_GENERATED
  WHATSAPP_SENT
  FOLLOW_UP_DONE
  TASK_COMPLETED
  DEAL_WON
  DEAL_LOST
  CRM_SYNCED
  NOTE_ADDED
}

model Activity {
  id        String @id @default(cuid())
  type      ActivityType
  userId    String?
  companyId String?
  message   String
  metadata  Json?
  createdAt DateTime @default(now())

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([companyId])
  @@index([userId])
}

// ============================================================
// CEO OS — Daily Command Center
// ============================================================

// One row per calendar day: morning objectives + AI hourly plan,
// end-of-day accountability review + AI performance score.
model DailyPlan {
  id   String   @id @default(cuid())
  date DateTime @unique // normalised to midnight

  objectives Json // morning answers: revenue target, meetings, calls, follow-ups, proposals, BNI, deliveries, blockers
  schedule   Json // [{ time, activity, category, why }]
  briefing   String? // AI morning briefing text

  eodReview        Json? // evening answers: revenue closed, meetings done, proposals sent, ...
  performanceScore Int? // 0-100
  eodSummary       String? // AI suggestions + tomorrow plan

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

// ============================================================
// Settings & Counters
// ============================================================

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

// Sequential human-friendly IDs (DV-P-0001, DV-PR-0001)
model Counter {
  name  String @id
  value Int    @default(0)
}

// ============================================================
// HRMS — Employees, Projects, Attendance, Leave, Salary, Performance
// ============================================================

enum ProjectStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LEAVE
  HOLIDAY
}

enum LeaveType {
  CASUAL
  SICK
  EARNED
  UNPAID
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum SalaryStatus {
  DRAFT
  PAID
}

/// One-to-one HR profile for a User whose role is EMPLOYEE.
model EmployeeProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeCode String    @unique
  designation  String?
  department   String?
  phone        String?
  address      String?
  joinDate     DateTime?
  baseSalary   Float     @default(0) // monthly base — HR/admin only, never exposed to the employee
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([department])
}

/// A client delivery project. `value` is money and is NEVER returned to employees.
model Project {
  id          String        @id @default(cuid())
  name        String
  companyId   String?
  company     Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  description String?
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime?
  dueDate     DateTime?
  value       Float?        // contract value — admin/manager only
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  assignments ProjectAssignment[]

  @@index([status])
  @@index([companyId])
}

model ProjectAssignment {
  id         String   @id @default(cuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String? // their role on the project
  assignedAt DateTime @default(now())

  @@unique([projectId, userId])
  @@index([userId])
}

model Attendance {
  id       String           @id @default(cuid())
  userId   String
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  date     DateTime // date-only (IST midnight)
  checkIn  DateTime?
  checkOut DateTime?
  status   AttendanceStatus @default(PRESENT)
  note     String?

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

model LeaveRequest {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation("EmployeeLeaves", fields: [userId], references: [id], onDelete: Cascade)
  type         LeaveType   @default(CASUAL)
  startDate    DateTime
  endDate      DateTime
  reason       String?
  status       LeaveStatus @default(PENDING)
  reviewedById String?
  reviewedBy   User?       @relation("LeaveReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime    @default(now())

  @@index([userId])
  @@index([status])
}

model SalaryRecord {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  month      String // "yyyy-MM"
  baseSalary Float        @default(0)
  allowances Float        @default(0)
  deductions Float        @default(0)
  netPay     Float        @default(0)
  status     SalaryStatus @default(DRAFT)
  paidAt     DateTime?
  note       String?
  createdAt  DateTime     @default(now())

  @@unique([userId, month])
  @@index([userId])
}

model PerformanceReview {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation("EmployeeReviews", fields: [userId], references: [id], onDelete: Cascade)
  period       String // e.g. "2026-Q2" or "2026-07"
  reviewerId   String?
  reviewer     User?    @relation("ReviewAuthor", fields: [reviewerId], references: [id], onDelete: SetNull)
  rating       Int      @default(0) // 1-5
  strengths    String?
  improvements String?
  comments     String?
  createdAt    DateTime @default(now())

  @@index([userId])
}
