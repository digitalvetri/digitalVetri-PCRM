# ===== Database (PostgreSQL) =====
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/digitalvetri?schema=public"

# ===== Clerk Authentication =====
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# ===== AI Providers (at least one required; AI_PROVIDER picks the default) =====
# One of: openai | claude | gemini
AI_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash"
# Groq (OpenAI-compatible) — used as an automatic fallback when the primary
# provider is rate-limited/unavailable. Set AI_PROVIDER=groq to use it directly.
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"

# ===== Supabase Storage (files: proposals, exports, imports) =====
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="digitalvetri-files"

# ===== Google Maps (company import + location enrichment) =====
GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ===== DigitalVetri CRM Integration (sync qualified prospects) =====
DV_CRM_API_URL=""
DV_CRM_API_KEY=""

# ===== App =====
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===== Email sending (SMTP) — send generated emails directly to clients =====
# Use your business email's SMTP. Gmail/Workspace: smtp.gmail.com:587 with an
# App Password. Zoho: smtp.zoho.in:587. Leave blank to use "Open in mail app".
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""          # optional, defaults to SMTP_USER, e.g. "DigitalVetri <info@digitalvetri.com>"
SMTP_SECURE="false"   # "true" for port 465

# ===== WhatsApp Cloud API (OPTIONAL — direct API send) =====
# From Meta's WhatsApp Business Platform. Leave blank to use "Send on WhatsApp"
# (click-to-chat, no setup). API only sends free-form text within a 24h window;
# cold/first-contact messages require pre-approved templates.
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_API_VERSION="v20.0"
WHATSAPP_DEFAULT_COUNTRY="91"

# ===== Autonomous agent (Phase 2) =====
# Secret the scheduler presents to /api/cron/daily. Generate a long random string.
CRON_SECRET=""
# Lead auto-discovery source (set ONE). Google Places = best coverage but needs
# a billing card. Geoapify = free tier, no card (get a key at geoapify.com).
GOOGLE_PLACES_API_KEY=""
GEOAPIFY_API_KEY=""
